{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env"],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".output/**", ".cache/tsbuildinfo.json", "dist/**"]
    },
    "deploy": {
      "cache": false
    },
    "lint": {},
    "typecheck": {},
    "format": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  },
  "globalEnv": [
    "CI",
    "NODE_ENV",
    "SKIP_ENV_VALIDATION",
    "PORT",
    "VITE_CONVEX_URL",
    "CONVEX_DEPLOYMENT",
    "CONVEX_URL",
    "VITE_SENTRY_DSN",
    "VITE_POSTHOG_KEY",
    "VITE_POSTHOG_HOST",
    "AUTH_GOOGLE_ID",
    "AUTH_GOOGLE_SECRET",
    "AUTH_RESEND_KEY",
    "JWT_PRIVATE_KEY",
    "JWKS",
    "SITE_URL",
    "INNGEST_SIGNING_KEY",
    "INNGEST_EVENT_KEY",
    "LEMONSQUEEZY_API_KEY",
    "LEMONSQUEEZY_STORE_ID",
    "LEMONSQUEEZY_FREE_VARIANT_ID",
    "LEMONSQUEEZY_BOOST_PRODUCT_ID",
    "LEMONSQUEEZY_PLUS_VARIANT_ID",
    "LEMONSQUEEZY_WEBHOOK_SECRET",
    "DISCORD_WEBHOOK_URL"
  ]
}
