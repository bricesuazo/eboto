{
  "name": "@eboto/inngest",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./functions": "./src/functions/index.ts"
  },
  "typesVersions": {
    "*": {
      "client": [
        "./src/client.ts"
      ],
      "functions": [
        "./src/functions/index.ts"
      ]
    }
  },
  "scripts": {
    "clean": "git clean -xdf .turbo node_modules",
    "dev": "pnpm with-env npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "lint": "eslint",
    "format": "prettier --check \"**/*.{ts,md,json}\"",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@eboto/backend": "workspace:*",
    "convex": "catalog:",
    "inngest": "catalog:"
  },
  "devDependencies": {
    "@eboto/eslint-config": "workspace:*",
    "@eboto/prettier-config": "workspace:*",
    "@eboto/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "dotenv-cli": "10.0.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@eboto/eslint-config/base"
    ]
  },
  "prettier": "@eboto/prettier-config"
}
